<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="3" author="Rob Poghosyan">
        <preConditions onFail="MARK_RAN">
            <not><tableExists tableName="properties"/></not>
        </preConditions>

        <createTable tableName="properties">
            <column name="id" type="int" autoIncrement="true"><constraints primaryKey="true" nullable="false"/></column>
            <column name="user_id" type="int"><constraints nullable="false" foreignKeyName="properties_user_FK" referencedTableName="user" referencedColumnNames="id"/></column>
            <column name="title" type="varchar(255)"><constraints nullable="false"/></column>
            <column name="description" type="text"><constraints nullable="false"/></column>
            <column name="surface" type="int"><constraints nullable="false"/></column>
            <column name="rooms_count" type="int"/>
            <column name="bathrooms_count" type="int"/>
            <column name="floor_count" type="int"/>
            <column name="floor" type="int"><constraints nullable="false"/></column>
            <column name="price" type="decimal(10,0)"><constraints nullable="false"/></column>
            <column name="created_at" type="date"><constraints nullable="false"/></column>
            <column name="location_id" type="int"><constraints nullable="false" foreignKeyName="properties_location_FK" referencedTableName="location" referencedColumnNames="id"/></column>
            <column name="status" type="enum('FOR_SALE','FOR_RENT','SOLD','RANTED')"><constraints nullable="false"/></column>
            <column name="type" type="enum('HOUSE','APARTAMENT','LAND')"><constraints nullable="false"/></column>
        </createTable>

        <rollback>
            <dropTable tableName="properties"/>
        </rollback>
    </changeSet>
</databaseChangeLog>
