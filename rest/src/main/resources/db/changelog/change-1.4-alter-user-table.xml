<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="5-enabled" author="HakobAvagyan">
        <preConditions onFail="MARK_RAN">
            <and>
                <tableExists tableName="user"/>
                <not><columnExists tableName="user" columnName="enabled"/></not>
            </and>
        </preConditions>
        <addColumn tableName="user">
            <column name="enabled" type="boolean"/>
        </addColumn>
        <rollback>
            <dropColumn tableName="user" columnName="enabled"/>
        </rollback>
    </changeSet>

    <changeSet id="5-verification-code" author="HakobAvagyan">
        <preConditions onFail="MARK_RAN">
            <and>
                <tableExists tableName="user"/>
                <not><columnExists tableName="user" columnName="verification_code"/></not>
            </and>
        </preConditions>
        <addColumn tableName="user">
            <column name="verification_code" type="varchar(255)"/>
        </addColumn>
        <rollback>
            <dropColumn tableName="user" columnName="verification_code"/>
        </rollback>
    </changeSet>

</databaseChangeLog>