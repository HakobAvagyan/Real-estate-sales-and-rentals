<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">
    <changeSet id="1" author="Rob Poghosyan">
        <preConditions onFail="MARK_RAN">
            <and>
                <not><tableExists tableName="user"/></not>
                <not><tableExists tableName="location"/></not>
                <not><tableExists tableName="currency"/></not>
                <not><tableExists tableName="urgent_sell_plane"/></not>
            </and>
        </preConditions>

        <createTable tableName="user">
            <column name="id" type="int" autoIncrement="true"><constraints primaryKey="true" nullable="false"/></column>
            <column name="name" type="varchar(255)"><constraints nullable="false"/></column>
            <column name="surname" type="varchar(255)"><constraints nullable="false"/></column>
            <column name="email" type="varchar(255)"><constraints nullable="false"/></column>
            <column name="phone" type="varchar(255)"><constraints nullable="false"/></column>
            <column name="password" type="varchar(255)"><constraints nullable="false"/></column>
            <column name="passport_details" type="varchar(255)"><constraints nullable="false"/></column>
            <column name="pic_name" type="varchar(255)"><constraints nullable="true"/></column>
            <column name="role" type="enum('ADMIN','MANAGER','USER')"><constraints nullable="false"/></column>
            <column name="is_blocked" type="tinyint(1)" defaultValueNumeric="0"><constraints nullable="false"/></column>
            <column name="created_at" type="date"><constraints nullable="false"/></column>
        </createTable>

        <createTable tableName="location">
            <column name="id" type="int" autoIncrement="true"><constraints primaryKey="true" nullable="false"/></column>
            <column name="region" type="enum('ԱՐԱԳԱԾՈՏՆ','ԱՐԱՐԱՏ','ԱՐՄԱՎԻՐ','ԳԵՂԱՐՔՈՒՆԻՔ','ԿՈՏԱՅՔ','ԼՈՌԻ','ՇԻՐԱԿ','ՍՅՈՒՆԻՔ','ՎԱՅՈՑ_ՁՈՐ','ՏԱՎՈՒՇ','ԵՐԵՎԱՆ')"><constraints nullable="false"/></column>
            <column name="city" type="varchar(255)"><constraints nullable="false"/></column>
            <column name="district" type="varchar(255)"><constraints nullable="false"/></column>
            <column name="street" type="varchar(255)"><constraints nullable="false"/></column>
        </createTable>

        <createTable tableName="currency">
            <column name="id" type="int" autoIncrement="true"><constraints primaryKey="true" nullable="false"/></column>
            <column name="code" type="varchar(255)"><constraints nullable="false"/></column>
            <column name="name" type="varchar(255)"><constraints nullable="false"/></column>
            <column name="symbol" type="varchar(255)"><constraints nullable="false"/></column>
            <column name="exchange_rate" type="decimal"><constraints nullable="false"/></column>
        </createTable>

        <createTable tableName="urgent_sell_plane">
            <column name="id" type="int" autoIncrement="true"><constraints primaryKey="true" nullable="false"/></column>
            <column name="duration_days" type="int"><constraints nullable="false"/></column>
            <column name="created_at" type="date"><constraints nullable="false"/></column>
            <column name="name" type="varchar(255)"><constraints nullable="false"/></column>
            <column name="is_active" type="tinyint(1)" defaultValueNumeric="0"><constraints nullable="false"/></column>
            <column name="update_at" type="date"><constraints nullable="false"/></column>
        </createTable>

        <rollback>
            <dropTable tableName="urgent_sell_plane"/>
            <dropTable tableName="currency"/>
            <dropTable tableName="location"/>
            <dropTable tableName="user"/>
        </rollback>
    </changeSet>
</databaseChangeLog>
