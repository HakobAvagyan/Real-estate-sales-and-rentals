<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="4" author="Rob Poghosyan">
        <preConditions onFail="MARK_RAN">
            <not><tableExists tableName="ad"/></not>
        </preConditions>

        <createTable tableName="ad_plans" ifNotExists="true">
            <column name="id" type="int" autoIncrement="true"><constraints primaryKey="true" nullable="false"/></column>
            <column name="name" type="varchar(255)"><constraints nullable="false"/></column>
            <column name="price" type="decimal(10,0)"><constraints nullable="false"/></column>
            <column name="duration_days" type="int"><constraints nullable="false"/></column>
            <column name="created_at" type="date"><constraints nullable="false"/></column>
            <column name="payment_id" type="int"><constraints nullable="false" foreignKeyName="ad_plans_payment_FK" referencedTableName="payment" referencedColumnNames="id"/></column>
        </createTable>

        <createTable tableName="ad">
            <column name="id" type="int" autoIncrement="true"><constraints primaryKey="true" nullable="false"/></column>
            <column name="images_url" type="varchar(255)"/><column name="video_url" type="varchar(255)"/>
            <column name="is_payed" type="tinyint(1)" defaultValueNumeric="0"><constraints nullable="false"/></column>
            <column name="is_blocked" type="tinyint(1)" defaultValueNumeric="0"><constraints nullable="false"/></column>
            <column name="user_id" type="int"><constraints nullable="false" foreignKeyName="ad_user_FK" referencedTableName="user" referencedColumnNames="id"/></column>
            <column name="ad_plans_id" type="int"><constraints nullable="false" foreignKeyName="ad_ad_plans_FK" referencedTableName="ad_plans" referencedColumnNames="id"/></column>
        </createTable>

        <createTable tableName="booking">
            <column name="id" type="int" autoIncrement="true"><constraints primaryKey="true" nullable="false"/></column>
            <column name="rented_start_date" type="date"><constraints nullable="false"/></column>
            <column name="rented_end_date" type="date"><constraints nullable="false"/></column>
            <column name="property_id" type="int"><constraints nullable="false" foreignKeyName="booking_properties_FK" referencedTableName="properties" referencedColumnNames="id"/></column>
            <column name="price" type="decimal(10,0)"><constraints nullable="false"/></column>
            <column name="payment_id" type="int"><constraints nullable="false" foreignKeyName="booking_payment_FK" referencedTableName="payment" referencedColumnNames="id"/></column>
        </createTable>

        <createTable tableName="property_urgent">
            <column name="id" type="int" autoIncrement="true"><constraints primaryKey="true" nullable="false"/></column>
            <column name="property_id" type="int"><constraints nullable="false" foreignKeyName="prop_urg_prop_FK" referencedTableName="properties" referencedColumnNames="id"/></column>
            <column name="urgent_sell_plan_id" type="int"><constraints nullable="false" foreignKeyName="prop_urg_plan_FK" referencedTableName="urgent_sell_plane" referencedColumnNames="id"/></column>
            <column name="start_date" type="date"><constraints nullable="false"/></column>
            <column name="end_date" type="date"><constraints nullable="false"/></column>
            <column name="is_active" type="tinyint(1)" defaultValueNumeric="0"><constraints nullable="false"/></column>
            <column name="created_at" type="date"><constraints nullable="false"/></column>
            <column name="payment_id" type="int"><constraints nullable="false" foreignKeyName="prop_urg_pay_FK" referencedTableName="payment" referencedColumnNames="id"/></column>
        </createTable>

        <createTable tableName="property_images">
            <column name="id" type="int" autoIncrement="true"><constraints primaryKey="true" nullable="false"/></column>
            <column name="property_id" type="int"><constraints nullable="false" foreignKeyName="prop_img_prop_FK" referencedTableName="properties" referencedColumnNames="id"/></column>
            <column name="images_url" type="varchar(255)"><constraints nullable="false"/></column>
            <column name="created_at" type="date"><constraints nullable="false"/></column>
        </createTable>

        <createTable tableName="property_360">
            <column name="id" type="int" autoIncrement="true"><constraints primaryKey="true" nullable="false"/></column>
            <column name="property_id" type="int"><constraints nullable="false" foreignKeyName="prop_360_prop_FK" referencedTableName="properties" referencedColumnNames="id"/></column>
            <column name="view_url" type="varchar(255)"><constraints nullable="false"/></column>
        </createTable>

        <createTable tableName="favorites">
            <column name="id" type="int" autoIncrement="true"><constraints primaryKey="true" nullable="false"/></column>
            <column name="property_id" type="int"><constraints nullable="false" unique="true" foreignKeyName="fav_prop_FK" referencedTableName="properties" referencedColumnNames="id"/></column>
            <column name="user_id" type="int"><constraints nullable="false" foreignKeyName="fav_user_FK" referencedTableName="user" referencedColumnNames="id"/></column>
            <column name="created_at" type="date"><constraints nullable="false"/></column>
        </createTable>

        <createTable tableName="comments">
            <column name="id" type="int" autoIncrement="true"><constraints primaryKey="true" nullable="false"/></column>
            <column name="comment" type="text"><constraints nullable="false"/></column>
            <column name="created_at" type="date"><constraints nullable="false"/></column>
            <column name="user_id" type="int"><constraints foreignKeyName="comm_user_FK" referencedTableName="user" referencedColumnNames="id"/></column>
            <column name="property_id" type="int"><constraints foreignKeyName="comm_prop_FK" referencedTableName="properties" referencedColumnNames="id"/></column>
        </createTable>

        <createTable tableName="ratings">
            <column name="id" type="int" autoIncrement="true"><constraints primaryKey="true" nullable="false"/></column>
            <column name="rating" type="int"><constraints nullable="false"/></column>
            <column name="property_id" type="int"><constraints foreignKeyName="rate_prop_FK" referencedTableName="properties" referencedColumnNames="id"/></column>
            <column name="user_id" type="int"><constraints foreignKeyName="rate_user_FK" referencedTableName="user" referencedColumnNames="id"/></column>
        </createTable>

        <createTable tableName="conversation">
            <column name="id" type="int" autoIncrement="true"><constraints primaryKey="true" nullable="false"/></column>
            <column name="user1_id" type="int"><constraints nullable="false" unique="true"/></column>
            <column name="user2_id" type="int"><constraints nullable="false" unique="true"/></column>
            <column name="created_at" type="date"><constraints nullable="false"/></column>
        </createTable>
        <addForeignKeyConstraint baseTableName="conversation" baseColumnNames="user1_id"
                                 constraintName="conv_u1_FK" referencedTableName="user" referencedColumnNames="id"
                                 onDelete="CASCADE"/>

        <addForeignKeyConstraint baseTableName="conversation" baseColumnNames="user2_id"
                                 constraintName="conv_u2_FK" referencedTableName="user" referencedColumnNames="id"
                                 onDelete="CASCADE"/>

        <createTable tableName="message_chat">
            <column name="id" type="int" autoIncrement="true"><constraints primaryKey="true" nullable="false"/></column>
            <column name="conversation_id" type="int"><constraints nullable="false"/></column>
            <column name="user_send_id" type="int"><constraints nullable="false" foreignKeyName="msg_user_FK" referencedTableName="user" referencedColumnNames="id"/></column>
            <column name="text" type="varchar(255)"><constraints nullable="false"/></column>
            <column name="is_read" type="tinyint(1)" defaultValueNumeric="0"><constraints nullable="false"/></column>
            <column name="created_at" type="date"><constraints nullable="false"/></column>
        </createTable>

        <addForeignKeyConstraint baseTableName="message_chat" baseColumnNames="conversation_id"
                                 constraintName="msg_conv_FK" referencedTableName="conversation" referencedColumnNames="id"
                                 onDelete="CASCADE"/>

        <createTable tableName="notification">
            <column name="id" type="int" autoIncrement="true"><constraints primaryKey="true" nullable="false"/></column>
            <column name="user_id" type="int"><constraints nullable="false"/></column>
            <column name="message" type="varchar(255)"><constraints nullable="false"/></column>
            <column name="title" type="varchar(255)"><constraints nullable="false"/></column>
            <column name="created_at" type="date"><constraints nullable="false"/></column>
        </createTable>

        <addForeignKeyConstraint baseTableName="notification" baseColumnNames="user_id"
                                 constraintName="notif_user_FK" referencedTableName="user" referencedColumnNames="id"
                                 onDelete="CASCADE"/>

        <rollback>
            <dropTable tableName="notification"/><dropTable tableName="meassage_chat"/><dropTable tableName="conversation"/>
            <dropTable tableName="ratings"/><dropTable tableName="comments"/><dropTable tableName="favorites"/>
            <dropTable tableName="property_360"/><dropTable tableName="property_images"/><dropTable tableName="property_urgent"/>
            <dropTable tableName="booking"/><dropTable tableName="ad"/>
        </rollback>
    </changeSet>
</databaseChangeLog>
