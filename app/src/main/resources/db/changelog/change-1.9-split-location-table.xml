<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="9" author="hakobavagyan">
        <preConditions onFail="MARK_RAN">
            <and>
                <tableExists tableName="location"/>
                <not><tableExists tableName="location_names"/></not>
            </and>
        </preConditions>

        <createTable tableName="location_names">
            <column name="id" type="int" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="region" type="enum('ԱՐԱԳԱԾՈՏՆ','ԱՐԱՐԱՏ','ԱՐՄԱՎԻՐ','ԳԵՂԱՐՔՈՒՆԻՔ','ԿՈՏԱՅՔ','ԼՈՌԻ','ՇԻՐԱԿ','ՍՅՈՒՆԻՔ','ՎԱՅՈՑ ՁՈՐ','ՏԱՎՈՒՇ','ԵՐԵՎԱՆ')">
                <constraints nullable="false"/>
            </column>
            <column name="city" type="varchar(255)">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addUniqueConstraint tableName="location_names"
                             columnNames="region, city"
                             constraintName="uq_location_names_region_city"/>

        <addColumn tableName="location">
            <column name="location_name_id" type="int"/>
        </addColumn>

        <sql>
            INSERT INTO location_names(region, city)
            SELECT DISTINCT l.region, l.city
            FROM location l;
        </sql>

        <sql>
            UPDATE location l
            JOIN location_names ln ON ln.region = l.region AND ln.city = l.city
            SET l.location_name_id = ln.id;
        </sql>

        <addNotNullConstraint tableName="location"
                              columnName="location_name_id"
                              columnDataType="int"/>

        <addForeignKeyConstraint baseTableName="location"
                                 baseColumnNames="location_name_id"
                                 referencedTableName="location_names"
                                 referencedColumnNames="id"
                                 constraintName="fk_location_location_name"/>

        <dropColumn tableName="location" columnName="region"/>
        <dropColumn tableName="location" columnName="city"/>

        <rollback>
            <addColumn tableName="location">
                <column name="region" type="enum('ԱՐԱԳԱԾՈՏՆ','ԱՐԱՐԱՏ','ԱՐՄԱՎԻՐ','ԳԵՂԱՐՔՈՒՆԻՔ','ԿՈՏԱՅՔ','ԼՈՌԻ','ՇԻՐԱԿ','ՍՅՈՒՆԻՔ','ՎԱՅՈՑ ՁՈՐ','ՏԱՎՈՒՇ','ԵՐԵՎԱՆ')"/>
                <column name="city" type="varchar(255)"/>
            </addColumn>
            <sql>
                UPDATE location l
                JOIN location_names ln ON ln.id = l.location_name_id
                SET l.region = ln.region, l.city = ln.city;
            </sql>
            <dropForeignKeyConstraint baseTableName="location" constraintName="fk_location_location_name"/>
            <dropColumn tableName="location" columnName="location_name_id"/>
            <dropTable tableName="location_names"/>
        </rollback>
    </changeSet>
</databaseChangeLog>
