<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="2.5.1-property-moderation-status" author="system">
        <preConditions onFail="MARK_RAN">
            <not>
                <columnExists tableName="properties" columnName="moderation_status"/>
            </not>
        </preConditions>
        <addColumn tableName="properties">
            <column name="moderation_status" type="varchar(32)" defaultValue="APPROVED">
                <constraints nullable="false"/>
            </column>
        </addColumn>
    </changeSet>
</databaseChangeLog>
