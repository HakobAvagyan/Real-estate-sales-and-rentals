<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="6-birth-date" author="Rob Poghosyan">
        <preConditions onFail="MARK_RAN">
            <and>
                <tableExists tableName="user"/>
                <not><columnExists tableName="user" columnName="birth_date"/></not>
            </and>
        </preConditions>
        <addColumn tableName="user">
            <column name="birth_date" type="date"/>
        </addColumn>
        <rollback>
            <dropColumn tableName="user" columnName="birth_date"/>
        </rollback>
    </changeSet>

    <changeSet id="6-gender" author="Rob Poghosyan">
        <preConditions onFail="MARK_RAN">
            <and>
                <tableExists tableName="user"/>
                <not><columnExists tableName="user" columnName="gender"/></not>
            </and>
        </preConditions>
        <addColumn tableName="user">
            <column name="gender" type="enum('MALE','FEMALE')"/>
        </addColumn>
        <rollback>
            <dropColumn tableName="user" columnName="gender"/>
        </rollback>
    </changeSet>
</databaseChangeLog>
