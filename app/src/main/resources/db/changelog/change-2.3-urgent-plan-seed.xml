<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="2.3" author="sam">
        <preConditions onFail="MARK_RAN">
            <sqlCheck expectedResult="0">SELECT COUNT(*) FROM urgent_sell_plane</sqlCheck>
        </preConditions>
        <insert tableName="urgent_sell_plane">
            <column name="name" value="Standard Urgent Plan"/>
            <column name="duration_days" valueNumeric="30"/>
            <column name="is_active" valueNumeric="1"/>
            <column name="created_at" valueDate="2026-04-18"/>
            <column name="update_at" valueDate="2026-04-18"/>
        </insert>
    </changeSet>

</databaseChangeLog>
